{
  "name": "nass-mazao-255",
  "version": "2.0.1",
  "description": "NASS MAZAO 255 Business Manager - Production Electron Desktop App",
  "main": "src/main/main.js",
  "author": "NASS MAZAO 255",
  "license": "MIT",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "dist": "electron-builder --win nsis --x64",
    "publish": "electron-builder --win nsis --x64 --publish always",
    "release:patch": "npm version patch && npm run publish"
  },
  "dependencies": {
    "electron-updater": "^6.3.9",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.nassmazao255.businessmanager",
    "productName": "NASS MAZAO 255 Business Manager",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "package.json",
      "build/**/*"
    ],
    "asarUnpack": [
      "node_modules/sqlite3/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "NASS MAZAO 255"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "issanass11",
        "repo": "nass-mazao-255",
        "releaseType": "release"
      }
    ]
  }
}
