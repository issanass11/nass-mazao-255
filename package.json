{
  "name": "nass-mazao-255-business-manager",
  "version": "1.0.1",
  "description": "NASS MAZAO 255 Business Manager - Electron Windows App",
  "main": "src/main.js",
  "author": "NASS MAZAO 255",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win nsis --x64",
    "publish": "electron-builder --win nsis --x64 --publish always",
    "release": "npm version patch && npm run publish"
  },
  "dependencies": {
    "electron-updater": "latest"
  },
  "devDependencies": {
    "electron": "latest",
    "electron-builder": "latest"
  },
  "build": {
    "appId": "com.nassmazao255.businessmanager",
    "productName": "NASS MAZAO 255 Business Manager",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "src/assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "NASS MAZAO 255"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "issanass11",
        "repo": "nass-mazao-255-business-manager",
        "releaseType": "release"
      }
    ]
  }
}