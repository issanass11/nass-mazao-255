{
  "name": "nass-mazao-255",
  "version": "1.1.0",
  "description": "NASS MAZAO 255 Enterprise Business Manager for crops trading",
  "main": "src/main/main.js",
  "author": "Issa Nass",
  "license": "MIT",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win nsis --publish=never",
    "release": "electron-builder --win nsis --publish=always"
  },
  "dependencies": {
    "better-sqlite3": "^12.4.1",
    "electron-updater": "^6.6.2"
  },
  "devDependencies": {
    "electron": "^38.2.2",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.issanass.nassmazao255",
    "productName": "NASS MAZAO 255",
    "directories": { "output": "release" },
    "files": ["src/**/*", "package.json"],
    "publish": [{ "provider": "github", "owner": "issanass11", "repo": "nass-mazao-255" }],
    "win": { "target": "nsis" },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "NASS MAZAO 255"
    }
  }
}
